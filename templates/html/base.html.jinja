<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{{ page_title }}</title>
  <meta name="description" content="{{ description }}" />
  <meta name="robots" content="index,follow" />
  <link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'%3E%3Crect width='32' height='32' rx='3' fill='%23111820'/%3E%3Crect x='20' y='20' width='8' height='8' fill='white'/%3E%3C/svg%3E" />
  <link rel="canonical" href="{{ canonical_url }}" />
  <meta property="og:type" content="profile" />
  <meta property="og:title" content="{{ page_title }}" />
  <meta property="og:description" content="{{ description }}" />
  <meta property="og:url" content="{{ canonical_url }}" />
  {% if pdf_filename %}
  <link rel="alternate" type="application/pdf" href="{{ pdf_filename }}" />
  {% endif %}
  <style>
{{ styles }}
  </style>
</head>
<body>
  <main class="rg-document rg-document--{{ doc_slug }}" lang="en">
    <aside class="rg-identity" aria-label="Scrutable™ identity and record metadata">
      <div class="rg-identity__brand">
        <p class="rg-identity__wordmark">{{ identity.marks.wordmark }}</p>
        <p class="rg-identity__promise">{{ identity.marks.promise }}</p>
      </div>
      <dl class="rg-record">
        <div><dt>Record</dt><dd>{{ record.id }}</dd></div>
        <div><dt>Class</dt><dd>{{ record["class"] }}</dd></div>
        <div><dt>Revision</dt><dd>{{ record.revision }}</dd></div>
        <div><dt>Status</dt><dd>{{ record.status }}</dd></div>
        <div><dt>Effective</dt><dd>{{ record.effective_date }}</dd></div>
      </dl>
      <span class="rg-identity__appendage" aria-hidden="true"></span>
    </aside>
    <header class="rg-document__header">
      <h1 class="rg-document__name">{{ full_name }}</h1>
      {% if position %}
      <p class="rg-document__position">{{ position }}</p>
      {% endif %}
      {% if contact_items %}
      <ul class="rg-document__contact">
        {% for item in contact_items %}
        <li>{% if item.href %}<a href="{{ item.href }}">{{ item.label }}</a>{% else %}{{ item.label }}{% endif %}</li>
        {% endfor %}
      </ul>
      {% endif %}
      {% if quote %}
      <blockquote class="rg-document__quote">{{ quote }}</blockquote>
      {% endif %}
    </header>
{{ sections_html }}
    <footer class="rg-document__footer">
      <span>{{ record.id }} · {{ record.status }} · {{ record.effective_date }}</span>
      <span>Generated from <a href="{{ source_repo }}">About-Me</a>.</span>
      {% if pdf_filename %}
      <span><a href="{{ pdf_filename }}">Download PDF</a></span>
      {% endif %}
    </footer>
  </main>
</body>
</html>
