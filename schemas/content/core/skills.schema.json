{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Skills content",
  "type": "object",
  "required": ["technical"],
  "properties": {
    "technical": {"$ref": "#/$defs/skills"},
    "professional": {"$ref": "#/$defs/skills"},
    "leadership_resume": {"type": "object"}
  },
  "$defs": {
    "skills": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["category", "items"],
        "properties": {
          "category": {"type": "string"},
          "items": {
            "oneOf": [
              {"type": "string"},
              {"type": "array", "items": {"type": "string"}}
            ]
          }
        }
      }
    }
  }
}
